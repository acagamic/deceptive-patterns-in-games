---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { refYear, refAuthors, CATEGORY_LABEL, type CSL } from "../../lib/refs";

const refs = (await getCollection("references")).map((r) => r.data as unknown as CSL);
const order = ["paper", "book", "report", "legal"];
const SINGULAR: Record<string, string> = {
  paper: "Paper",
  book: "Book",
  report: "Report",
  legal: "Legal",
};
const groups = order
  .map((cat) => ({
    cat,
    label: CATEGORY_LABEL[cat] ?? cat,
    items: refs
      .filter((r) => (r.category ?? "paper") === cat)
      .sort(
        (a, b) =>
          (a.author?.[0]?.family ?? a.title).localeCompare(
            b.author?.[0]?.family ?? b.title,
          ) || refYear(a).localeCompare(refYear(b)),
      ),
  }))
  .filter((g) => g.items.length > 0);

const sourceLine = (r: CSL) =>
  r.DOI ? `doi.org/${r.DOI}` : r.URL ? r.URL.replace(/^https?:\/\//, "") : "";
---

<Base
  title="References"
  description="The resolvable bibliography behind every pattern — DOI-linked scholarship, books, reports, legal sources, and selected primary web sources, each as a citable card."
>
  <section class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="font-serif text-3xl font-bold text-ink sm:text-4xl">References</h1>
    <p class="mt-2 max-w-2xl text-muted">
      {refs.length} sources behind the catalogue — DOI-linked scholarship where
      available, plus books, reports, legal sources, and selected primary web
      sources that document a mechanism directly. Each card opens the full
      citation, with BibTeX and CSL-JSON exports.
    </p>

    {
      groups.map((g) => (
        <section class="mt-10">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-muted">
            {g.label} ({g.items.length})
          </h2>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            {g.items.map((r) => (
              <a
                href={`/references/${r.id}`}
                class="group flex flex-col rounded-2xl border border-border bg-paper p-5 card-hover-effect btn-press-active"
              >
                <div class="flex items-center justify-between gap-2">
                  <span class="font-mono text-[10px] uppercase tracking-wider text-muted">
                    {SINGULAR[g.cat] ?? g.label}
                  </span>
                  <span class="font-mono text-[10px] text-muted">{refYear(r)}</span>
                </div>
                <h3 class="mt-2 font-sans text-sm font-semibold leading-snug tracking-tight text-ink transition-colors duration-150 group-hover:text-accent">
                  {r.title}
                </h3>
                <p class="mt-1 text-xs text-muted">{refAuthors(r)}</p>
                {r["container-title"] && (
                  <p class="mt-0.5 text-xs italic text-muted">{r["container-title"]}</p>
                )}
                <div class="flex-1" />
                {sourceLine(r) && (
                  <span class="mt-3 break-words text-xs text-link">{sourceLine(r)}</span>
                )}
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</Base>
