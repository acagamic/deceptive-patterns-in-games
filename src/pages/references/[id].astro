---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Badge from "../../components/Badge.astro";
import {
  formatRef,
  refYear,
  refAuthors,
  formatAPA,
  formatACM,
  CATEGORY_LABEL,
  type CSL,
} from "../../lib/refs";
import { allPatterns, sevTone } from "../../lib/patterns";

export async function getStaticPaths() {
  const refs = await getCollection("references");
  return refs.map((r) => ({ params: { id: r.id }, props: { ref: r.data } }));
}

const ref = Astro.props.ref as unknown as CSL;
const patterns = await allPatterns();
const citedBy = patterns.filter((p) => p.data.references.includes(ref.id));
const glossary = (await getCollection("glossary")).filter((g) =>
  g.data.references.includes(ref.id),
);

const bibType =
  {
    "article-journal": "article",
    "paper-conference": "inproceedings",
    chapter: "incollection",
    report: "techreport",
  }[ref.type] ?? "misc";
const bibAuthors = (ref.author ?? [])
  .map((a) => a.literal ?? `${a.family ?? ""}, ${a.given ?? ""}`.replace(/, $/, ""))
  .join(" and ");
const venueField = ref.type === "article-journal" ? "journal" : "booktitle";
const bibtex = `@${bibType}{${ref.id},
  author    = {${bibAuthors}},
  title     = {${ref.title}},
  ${ref["container-title"] ? `${venueField} = {${ref["container-title"]}},\n  ` : ""}year      = {${refYear(ref)}},${ref.publisher ? `\n  publisher = {${ref.publisher}},` : ""}${ref.DOI ? `\n  doi       = {${ref.DOI}},` : ""}${ref.URL ? `\n  url       = {${ref.URL}}` : ""}
}`;

const formats = [
  { id: "bibtex", label: "BibTeX", text: bibtex, mono: true },
  { id: "apa", label: "APA", text: formatAPA(ref), mono: false },
  { id: "acm", label: "ACM SIGCHI", text: formatACM(ref), mono: false },
];
---

<Base title={ref.title} description={formatRef(ref)}>
  <article class="mx-auto max-w-3xl px-4 py-10" data-pagefind-body>
    <nav class="mb-4 text-xs text-muted">
      <a href="/references" class="hover:text-accent">References</a>
      <span class="px-1">/</span><span class="font-mono">{ref.id}</span>
    </nav>
    <div hidden><span data-pagefind-filter="type">Reference</span></div>

    <Badge label={CATEGORY_LABEL[ref.category ?? "paper"] ?? "Paper"} tone="neutral" />
    <h1 class="mt-2 font-serif text-2xl font-bold leading-snug text-ink sm:text-3xl">
      {ref.title}
    </h1>
    <p class="mt-3 text-muted">{refAuthors(ref)} · {refYear(ref)}</p>
    {ref["container-title"] && <p class="text-muted italic">{ref["container-title"]}</p>}

    {
      ref.DOI ? (
        <a
          class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-brand-ink hover:opacity-90"
          href={ref.URL ?? `https://doi.org/${ref.DOI}`}
          rel="noopener"
        >
          View at doi.org/{ref.DOI}
        </a>
      ) : ref.URL ? (
        <a
          class="mt-4 inline-flex items-center gap-2 rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-brand-ink hover:opacity-90"
          href={ref.URL}
          rel="noopener"
        >
          View source ↗
        </a>
      ) : null
    }

    {
      citedBy.length > 0 && (
        <section class="mt-10">
          <h2 class="font-serif text-xl font-semibold text-ink">
            Patterns citing this source
          </h2>
          <ul class="mt-3 space-y-2">
            {citedBy.map((p) => (
              <li>
                <a
                  class="flex items-center justify-between gap-3 rounded-lg border border-border bg-paper px-4 py-2.5 hover:border-accent/50"
                  href={`/patterns/${p.id}`}
                >
                  <span class="text-ink">{p.data.title}</span>
                  <Badge label={p.data.severity} tone={sevTone(p.data.severity)} />
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      glossary.length > 0 && (
        <section class="mt-8">
          <h2 class="font-serif text-xl font-semibold text-ink">
            Glossary entries citing this source
          </h2>
          <ul class="mt-3 flex flex-wrap gap-2">
            {glossary.map((g) => (
              <li>
                <a
                  class="rounded-full border border-border px-3 py-1 text-sm text-link hover:border-accent/50"
                  href={`/glossary/${g.id}`}
                >
                  {g.data.term}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="mt-10">
      <h2 class="font-serif text-xl font-semibold text-ink">Cite this</h2>
      <div
        class="citebox mt-3 overflow-hidden rounded-lg border border-border bg-surface/40"
        data-citebox
      >
        <div
          class="flex items-center justify-between gap-2 border-b border-border px-2 py-1.5"
        >
          <div class="flex flex-wrap gap-1" role="tablist" aria-label="Citation format">
            {
              formats.map((f, i) => (
                <button
                  type="button"
                  class="citetab rounded-md px-2.5 py-1 text-xs font-medium text-muted transition-colors hover:text-ink aria-selected:bg-paper aria-selected:text-ink"
                  role="tab"
                  aria-selected={i === 0 ? "true" : "false"}
                  data-tab={f.id}
                >
                  {f.label}
                </button>
              ))
            }
          </div>
          <button
            type="button"
            class="citecopy inline-flex shrink-0 items-center gap-1.5 rounded-md border border-border px-2 py-1 text-xs text-muted transition-colors hover:text-ink"
            aria-label="Copy citation to clipboard"
          >
            <svg
              class="h-3.5 w-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="11" height="11" rx="2"></rect>
              <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
            </svg>
            <span class="citecopy-label">Copy</span>
          </button>
        </div>
        {
          formats.map((f, i) =>
            f.mono ? (
              <pre
                class="citepanel m-0 overflow-x-auto px-3 py-3 font-mono text-xs leading-relaxed text-ink"
                data-panel={f.id}
                hidden={i !== 0}
              >{f.text}</pre>
            ) : (
              <p
                class="citepanel m-0 px-3 py-3 text-xs leading-relaxed text-ink"
                data-panel={f.id}
                hidden={i !== 0}
              >{f.text}</p>
            ),
          )
        }
      </div>
    </section>
  </article>

  <script>
    for (const box of document.querySelectorAll<HTMLElement>("[data-citebox]")) {
      const tabs = box.querySelectorAll<HTMLButtonElement>(".citetab");
      const panels = box.querySelectorAll<HTMLElement>(".citepanel");
      const copyBtn = box.querySelector<HTMLButtonElement>(".citecopy");
      const label = box.querySelector<HTMLElement>(".citecopy-label");
      const show = (id: string) => {
        tabs.forEach((t) => t.setAttribute("aria-selected", String(t.dataset.tab === id)));
        panels.forEach((p) => (p.hidden = p.dataset.panel !== id));
      };
      tabs.forEach((t) =>
        t.addEventListener("click", () => t.dataset.tab && show(t.dataset.tab)),
      );
      copyBtn?.addEventListener("click", async () => {
        const active = box.querySelector<HTMLElement>(".citepanel:not([hidden])");
        const text = (active?.textContent ?? "").trim();
        if (!text || !label) return;
        try {
          await navigator.clipboard.writeText(text);
          label.textContent = "Copied";
        } catch {
          label.textContent = "Copy failed";
        }
        setTimeout(() => {
          label.textContent = "Copy";
        }, 1500);
      });
    }
  </script>
</Base>
