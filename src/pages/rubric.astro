---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import Badge from "../components/Badge.astro";
import ScatterViz from "../components/ScatterViz.astro";

const rubric = await getCollection("rubric");
const modes = await getCollection("modes");

const spectrum = [
  { label: "Acceptable", tone: "sev-low" },
  { label: "Concerning", tone: "sev-medium" },
  { label: "Harmful", tone: "sev-high" },
  { label: "Impermissible", tone: "sev-severe" },
];
const segBg: Record<string, string> = {
  "sev-low": "bg-sev-low",
  "sev-medium": "bg-sev-medium",
  "sev-high": "bg-sev-high",
  "sev-severe": "bg-sev-severe",
};

const tiers = [
  {
    n: "Tier 1",
    tone: "text-sev-severe",
    head: "Strongest evidence · candidates for prohibition",
    body: "Randomised paid mechanics (loot boxes/gacha), especially with hidden odds and especially to minors; manipulative monetisation targeting children.",
  },
  {
    n: "Tier 2",
    tone: "text-sev-high",
    head: "Clear consumer detriment · growing evidence",
    body: "Obstructed exit / sludge, hidden costs, premium-currency obfuscation, aggressive FOMO, and pay-to-win in competitive contexts.",
  },
  {
    n: "Tier 3",
    tone: "text-sev-medium",
    head: "Context-dependent · harmful mainly under the rubric",
    body: "Grinding, daily streaks, timers, and social/parasocial nudges — ordinary engagement design that turns harmful chiefly when combined with monetisation, covert operation, or vulnerable targets.",
  },
];

const brightLines = [
  "Paid randomised rewards (loot boxes/gacha) offered to children, or in games rated for minors.",
  "Undisclosed probabilities on any paid randomised reward.",
  "Real-money cost obfuscation (multi-step currency laundering) targeting minors.",
  "Obstructed cancellation / refund and withdrawal “sludge” on recurring or large spends.",
  "Ads disguised as gameplay, and purchase-as-default UI in children's titles.",
  "Designs that individually profile and price to maximise a specific player's spend.",
];

const severityScale = [
  { level: "Low", tone: "sev-low", note: "Trivial or easily reversed stakes — a mild, resistible nudge." },
  { level: "Medium", tone: "sev-medium", note: "Real but bounded detriment; depends heavily on context and dose." },
  { level: "High", tone: "sev-high", note: "Clear, substantial loss of money, time, or autonomy." },
  { level: "Severe", tone: "sev-severe", note: "Large or escalating loss, or harm aimed at the vulnerable — a prohibition candidate." },
];

const evidenceScale = [
  { level: "Emerging", tone: "ev-emerging", note: "Early or indirect: theory, a single study, an expert report, or analogy from another domain." },
  { level: "Moderate", tone: "ev-moderate", note: "Several studies or consistent correlational findings; recognised in the literature." },
  { level: "Strong", tone: "ev-strong", note: "Replicated, meta-analytic, or convergent evidence — e.g. loot boxes and problem gambling." },
];
---

<Base
  title="When does it become harmful?"
  description="Harm is conditional. An eight-dimension rubric, a severity gradient, the five modes of adversarial design, and a bright-line do-not-ship list."
>
  <section class="mx-auto max-w-4xl px-4 py-10" data-pagefind-body>
    <h1 class="font-sans text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      When does a pattern become harmful?
    </h1>
    <p class="mt-4 max-w-2xl text-base sm:text-lg leading-relaxed text-muted">
      Deception is not the same as harm. The descriptive catalogue says what a
      technique <em>is</em>; this rubric is the separate judgement layer that
      says how bad a given instance is.
    </p>

    <section class="mt-8 rounded-2xl border border-border bg-surface p-6">
      <h2 class="font-sans text-lg font-bold tracking-tight text-ink">
        First: whose purpose does it serve?
      </h2>
      <p class="mt-2 max-w-3xl text-xs sm:text-sm leading-relaxed text-muted">
        Before weighing how harmful a mechanic is, ask <em>why it exists</em>.
        Every pattern here is tagged by the purpose it serves — a fast first test
        for separating a standard game mechanic from a deceptive one.
      </p>
      <div class="mt-5 grid gap-4 text-xs sm:grid-cols-3">
        <div class="rounded-2xl border border-sev-low/20 bg-sev-low/8 p-5">
          <div class="text-sm font-bold tracking-tight text-sev-low">Serves gameplay</div>
          <p class="mt-2 text-ink/80 leading-relaxed">
            Primarily for the player's experience — usually a standard mechanic,
            rarely deceptive on its own.
          </p>
        </div>
        <div class="rounded-2xl border border-sev-medium/20 bg-sev-medium/8 p-5">
          <div class="text-sm font-bold tracking-tight text-sev-medium">Gameplay &amp; business</div>
          <p class="mt-2 text-ink/80 leading-relaxed">
            Serves play and the provider at once — the contested middle where the
            conditions below decide.
          </p>
        </div>
        <div class="rounded-2xl border border-sev-severe/20 bg-sev-severe/8 p-5">
          <div class="text-sm font-bold tracking-tight text-sev-severe">Serves business</div>
          <p class="mt-2 text-ink/80 leading-relaxed">
            Primarily for revenue, retention, or data — the most suspect, and the
            clearest dark-pattern candidates.
          </p>
        </div>
      </div>
    </section>

    <!-- two scores: severity & evidence -->
    <section class="mt-8 rounded-2xl border border-border bg-surface p-6">
      <h2 class="font-sans text-lg font-bold tracking-tight text-ink">
        The two scores: severity &amp; evidence
      </h2>
      <p class="mt-2 max-w-3xl text-xs sm:text-sm leading-relaxed text-muted">
        Beyond purpose, every pattern carries two <em>independent</em> scores.
        <strong class="text-ink">Severity</strong> is how serious the harm can be when
        the pattern ships; <strong class="text-ink">evidence</strong> is how strong the
        research base is that it actually causes harm. They are orthogonal — a pattern
        can be severe but barely studied, or well-evidenced yet modest — so the map
        below plots them on separate axes rather than collapsing them into one score.
      </p>
      <div class="mt-5 grid gap-x-8 gap-y-6 sm:grid-cols-2">
        <div>
          <h3 class="text-[10px] font-bold uppercase tracking-wider text-muted">
            Severity — how serious
          </h3>
          <ul class="mt-3 space-y-2.5">
            {
              severityScale.map((s) => (
                <li class="flex items-start gap-2.5 text-xs sm:text-sm leading-relaxed">
                  <Badge label={s.level} tone={s.tone} />
                  <span class="text-muted">{s.note}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h3 class="text-[10px] font-bold uppercase tracking-wider text-muted">
            Evidence — how sure
          </h3>
          <ul class="mt-3 space-y-2.5">
            {
              evidenceScale.map((e) => (
                <li class="flex items-start gap-2.5 text-xs sm:text-sm leading-relaxed">
                  <Badge label={e.level} tone={e.tone} />
                  <span class="text-muted">{e.note}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
      <figure class="mt-7">
        <ScatterViz />
      </figure>
    </section>

    <!-- spectrum -->
    <div class="mt-10">
      <div class="h-6 w-full rounded-full bg-gradient-to-r from-sev-low via-sev-medium via-sev-high to-sev-severe relative shadow-inner">
      </div>
      <div class="mt-3 grid grid-cols-4 text-center text-xs font-semibold tracking-tight text-ink">
        {
          spectrum.map((s) => (
            <div>{s.label}</div>
          ))
        }
      </div>
    </div>
    <p class="mt-2 text-right text-[10px] uppercase font-bold tracking-wider text-muted">increasing severity →</p>

    <!-- 8 dimensions -->
    <h2 class="mt-12 font-sans text-2xl font-bold tracking-tight text-ink">
      Eight conditions
    </h2>
    <p class="mt-2 text-xs sm:text-sm leading-relaxed text-muted">
      Each dimension pushes a given instance greener (more acceptable) or darker
      (more harmful). When locus + consent + vulnerability all tip darker, the
      case for “harmful” — and at the extreme “impermissible” — is strongest.
    </p>
    <div class="mt-6 overflow-x-auto">
      <table class="w-full border-collapse text-xs">
        <thead>
          <tr class="border-b border-border text-left">
            <th class="py-3 pr-4 text-[10px] font-bold uppercase tracking-wider text-ink">Dimension</th>
            <th class="py-3 pr-4 text-[10px] font-bold uppercase tracking-wider text-sev-low">Greener</th>
            <th class="py-3 text-[10px] font-bold uppercase tracking-wider text-sev-severe">Darker</th>
          </tr>
        </thead>
        <tbody>
          {
            rubric.map((r) => (
              <tr class="border-b border-border align-top">
                <td class="py-4 pr-4 font-bold text-ink sm:whitespace-nowrap">{r.data.dimension}</td>
                <td class="py-4 pr-4 text-ink/80 leading-relaxed">{r.data.greener}</td>
                <td class="py-4 text-ink/80 leading-relaxed">{r.data.darker}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <!-- severity tiers -->
    <h2 class="mt-16 font-sans text-2xl font-bold tracking-tight text-ink">Severity gradient</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      {
        tiers.map((t) => (
          <div class="rounded-2xl border border-border bg-paper p-5 card-hover-effect btn-press-active">
            <div class={`font-sans text-base font-bold tracking-tight ${t.tone}`}>{t.n}</div>
            <div class="mt-1 text-xs font-semibold text-ink">{t.head}</div>
            <p class="mt-2 text-xs leading-relaxed text-muted">{t.body}</p>
          </div>
        ))
      }
    </div>

    <!-- bright lines -->
    <h2 class="mt-16 font-sans text-2xl font-bold tracking-tight text-ink">
      Bright-line “do-not-ship” list
    </h2>
    <p class="mt-2 text-xs sm:text-sm leading-relaxed text-muted">
      The highest-confidence prohibitions, where the evidence and the rubric
      converge — specific enough for a regulator to enforce and a studio to test
      against.
    </p>
    <ol
      class="mt-5 space-y-3 rounded-2xl border border-sev-high/20 bg-sev-high/8 p-6 text-xs"
    >
      {
        brightLines.map((b, i) => (
          <li class="flex gap-3">
            <span class="font-mono font-bold text-sev-high text-sm leading-none">{i + 1}</span>
            <span class="text-ink leading-relaxed font-medium">{b}</span>
          </li>
        ))
      }
    </ol>

    <!-- modes -->
    <h2 id="modes" class="mt-16 scroll-mt-20 font-sans text-2xl font-bold tracking-tight text-ink">
      Five modes of adversarial design
    </h2>
    <p class="mt-2 text-xs sm:text-sm leading-relaxed text-muted">
      A family of near-synonyms, separated by <em>what exactly is wrong</em>.
      They stack: one feature can be several at once.
    </p>
    <div class="mt-6 space-y-4">
      {
        modes.map((m) => (
          <div class="rounded-2xl border border-border bg-paper p-5 card-hover-effect btn-press-active">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h3 class="font-sans text-base font-semibold tracking-tight text-ink">
                {m.data.title}
              </h3>
              <span class="text-[10px] font-bold uppercase tracking-wider text-muted">
                Intent: {m.data.needsIntent}
              </span>
            </div>
            <p class="mt-2 text-xs leading-relaxed text-ink/90">{m.data.wrong}</p>
            <p class="mt-2 text-[11px] leading-relaxed text-muted font-medium">
              Operates on {m.data.operatesOn.toLowerCase()} · e.g. {m.data.example}
            </p>
          </div>
        ))
      }
    </div>
  </section>
</Base>
