---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Badge from "../../components/Badge.astro";
import MetaTable from "../../components/MetaTable.astro";
import Citation from "../../components/Citation.astro";
import PatternCard from "../../components/PatternCard.astro";
import {
  allPatterns,
  relatedPatterns,
  labelMaps,
  sevTone,
  evTone,
} from "../../lib/patterns";
import community from "../../data/community.json";

export async function getStaticPaths() {
  const patterns = await getCollection("patterns");
  return patterns.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const maps = await labelMaps();
const all = await allPatterns();
const related = relatedPatterns(entry, all);
const comm = (community as Record<string, any>)[entry.id];
---

<Base title={d.title} description={d.summary}>
  <article class="mx-auto max-w-3xl px-4 py-10" data-pagefind-body>
    <nav class="mb-4 text-xs text-muted">
      <a href="/patterns" class="hover:text-accent">Patterns</a>
      <span class="px-1">/</span><span>{d.category}</span>
    </nav>

    <div class="flex flex-wrap items-center gap-2">
      <span class="font-mono text-sm text-muted">{d.code}</span>
      <Badge label={d.severity} tone={sevTone(d.severity)} />
      <Badge label={`Evidence: ${d.evidenceLevel}`} tone={evTone(d.evidenceLevel)} />
    </div>

    <h1 class="mt-2 font-serif text-3xl font-bold leading-tight text-ink sm:text-4xl">
      {d.title}
    </h1>
    <p class="mt-3 text-lg text-muted">{d.summary}</p>

    {/* Hidden Pagefind facet tags so site search can filter too */}
    <div hidden>
      <span data-pagefind-filter="type">Pattern</span>
      <span data-pagefind-filter="category">{d.category}</span>
      <span data-pagefind-filter="severity">{d.severity}</span>
      <span data-pagefind-filter="evidence">{d.evidenceLevel}</span>
      {d.platforms.map((pl) => <span data-pagefind-filter="platform">{pl}</span>)}
    </div>

    <div class="mt-6">
      <MetaTable
        pattern={entry}
        family={maps.family}
        harm={maps.harm}
        mode={maps.mode}
      />
    </div>

    <div class="prose-content mt-8"><Content /></div>

    {
      d.examples.length > 0 && (
        <section class="mt-8">
          <h2 class="font-serif text-xl font-semibold text-ink">
            Examples in the wild
          </h2>
          <ul class="mt-3 space-y-2">
            {d.examples.map((ex) => (
              <li class="rounded-lg border border-border bg-surface/50 px-4 py-2.5 text-sm text-ink">
                {ex}
              </li>
            ))}
          </ul>
          <p class="mt-2 text-xs text-muted">
            Illustrative genre examples to aid recognition — not allegations
            about specific titles.
          </p>
        </section>
      )
    }

    {
      d.references.length > 0 && (
        <section class="mt-8">
          <h2 class="font-serif text-xl font-semibold text-ink">References</h2>
          <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm">
            {d.references.map((id) => (
              <Citation id={id} />
            ))}
          </ol>
        </section>
      )
    }

    {
      comm && (
        <section class="mt-8">
          <h2 class="font-serif text-xl font-semibold text-ink">
            Community catalogue
          </h2>
          <div class="mt-3 rounded-xl border border-border bg-surface/50 p-4 text-sm">
            <p class="text-ink">
              The community site{" "}
              <a class="text-link underline" href="https://www.darkpattern.games" rel="noopener">DarkPattern.games</a>{" "}
              catalogues a related pattern,{" "}
              <a class="text-link underline" href={comm.url} rel="noopener">“{comm.title}”</a>, with {comm.exampleCount}+ community-reported example games
              {comm.examples.length > 0 ? `, including ${comm.examples.join(", ")}` : ""}.
            </p>
            <p class="mt-2 text-xs text-muted">
              Community-contributed and votes-based; the listed game titles are examples reported there, not our assessment.{" "}
              <a class="text-link underline" href={comm.url} rel="noopener">View on DarkPattern.games →</a>
            </p>
          </div>
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="mt-10">
          <h2 class="font-serif text-xl font-semibold text-ink">
            Related patterns
          </h2>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            {related.map((r) => (
              <PatternCard
                pattern={r}
                familyName={maps.family.get(r.data.family)}
              />
            ))}
          </div>
        </section>
      )
    }
  </article>
</Base>
