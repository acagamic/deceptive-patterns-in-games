---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Badge from "../../components/Badge.astro";
import PatternCard from "../../components/PatternCard.astro";
import { allPatterns, labelMaps, sevRank } from "../../lib/patterns";

export async function getStaticPaths() {
  const families = await getCollection("families");
  return families.map((f) => ({ params: { id: f.id }, props: { family: f } }));
}

const { family } = Astro.props;
const maps = await labelMaps();
const members = (await allPatterns())
  .filter((p) => p.data.family === family.id)
  .sort((a, b) => sevRank(b.data.severity) - sevRank(a.data.severity));
---

<Base title={family.data.title} description={family.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-10" data-pagefind-body>
    <nav class="mb-4 text-xs text-muted">
      <a href="/families" class="hover:text-accent">Mechanisms</a>
      <span class="px-1">/</span><span>{family.data.title}</span>
    </nav>
    <div class="flex items-center gap-2">
      <Badge label={family.data.kind} tone="neutral" />
    </div>
    <h1 class="mt-2 font-serif text-3xl font-bold text-ink sm:text-4xl">
      {family.data.title}
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-muted">{family.data.description}</p>

    <h2 class="mt-8 font-serif text-xl font-semibold text-ink">
      Patterns in this family <span class="text-muted">({members.length})</span>
    </h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {
        members.map((p) => (
          <PatternCard pattern={p} familyName={maps.family.get(p.data.family)} />
        ))
      }
    </div>
  </section>
</Base>
