---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { allPatterns } from "../../lib/patterns";

const families = await getCollection("families");
const patterns = await allPatterns();
const count = new Map<string, number>();
for (const p of patterns)
  count.set(p.data.family, (count.get(p.data.family) ?? 0) + 1);
const kinds = ["General", "Games-salient"] as const;
---

<Base
  title="Mechanism families"
  description="Axis A: the mechanism families that describe how a deceptive or exploitative pattern works."
>
  <section class="mx-auto max-w-4xl px-4 py-10">
    <h1 class="font-serif text-3xl font-bold text-ink sm:text-4xl">
      Mechanism families
    </h1>
    <p class="mt-2 max-w-2xl text-muted">
      Axis A — <em>how</em> a pattern works. General families recur across all
      digital products; games-salient families are specific to play.
    </p>

    {
      kinds.map((kind) => (
        <div class="mt-8">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-muted">
            {kind === "General" ? "General (cross-domain)" : "Games-salient"}
          </h2>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            {families
              .filter((f) => f.data.kind === kind)
              .map((f) => (
                <a
                  href={`/families/${f.id}`}
                  class="rounded-xl border border-border bg-paper p-4 transition hover:border-accent/50"
                >
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="font-serif text-lg font-semibold text-ink">
                      {f.data.title}
                    </h3>
                    <span class="text-xs text-muted">
                      {count.get(f.id) ?? 0} patterns
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-muted">{f.data.description}</p>
                </a>
              ))}
          </div>
        </div>
      ))
    }
  </section>
</Base>
