---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PatternCard from "../../components/PatternCard.astro";
import { allPatterns, labelMaps, sevRank } from "../../lib/patterns";

export async function getStaticPaths() {
  const harms = await getCollection("harms");
  return harms.map((h) => ({ params: { id: h.id }, props: { harm: h } }));
}

const { harm } = Astro.props;
const maps = await labelMaps();
const members = (await allPatterns())
  .filter((p) => p.data.harmVectors.includes(harm.id))
  .sort((a, b) => sevRank(b.data.severity) - sevRank(a.data.severity));
---

<Base title={`${harm.data.title} cost`} description={harm.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-10" data-pagefind-body>
    <nav class="mb-4 text-xs text-muted">
      <a href="/costs" class="hover:text-accent">Player Costs</a>
      <span class="px-1">/</span><span>{harm.data.title}</span>
    </nav>
    <h1 class="font-serif text-3xl font-bold text-ink sm:text-4xl">
      {harm.data.title}
    </h1>
    <p class="mt-3 max-w-2xl text-lg text-muted">{harm.data.description}</p>

    <h2 class="mt-8 font-serif text-xl font-semibold text-ink">
      Patterns that target this <span class="text-muted">({members.length})</span>
    </h2>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      {
        members.map((p) => (
          <PatternCard pattern={p} familyName={maps.family.get(p.data.family)} />
        ))
      }
    </div>
  </section>
</Base>
