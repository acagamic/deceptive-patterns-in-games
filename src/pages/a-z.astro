---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import { allPatterns, sevTone } from "../lib/patterns";

const patterns = await allPatterns();
const groups = new Map<string, typeof patterns>();
for (const p of patterns) {
  const letter = p.data.title[0].toUpperCase();
  if (!groups.has(letter)) groups.set(letter, []);
  groups.get(letter)!.push(p);
}
const letters = [...groups.keys()].sort();
---

<Base
  title="A–Z index"
  description="An alphabetical index of every deceptive, exploitative, and harmful design pattern in the library."
>
  <section class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="font-sans text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      A–Z index
    </h1>
    <p class="mt-2 text-muted">
      Every pattern, alphabetically. Looking for a concept instead? Try the
      <a class="text-link underline" href="/glossary">glossary</a>.
    </p>

    <nav class="mt-6 flex flex-wrap gap-1.5" aria-label="Jump to letter">
      {
        letters.map((l) => (
          <a
            href={`#letter-${l}`}
            class="rounded-full border border-border bg-paper px-3 py-1 text-xs font-semibold text-muted hover:bg-surface-2 hover:text-ink transition btn-press-active"
          >
            {l}
          </a>
        ))
      }
    </nav>

    {
      letters.map((l) => (
        <section id={`letter-${l}`} class="mt-8 scroll-mt-20">
          <h2 class="font-sans text-lg font-bold tracking-tight text-ink border-b border-border pb-1">{l}</h2>
          <ul class="mt-2 divide-y divide-border">
            {groups.get(l)!.map((p) => (
              <li>
                <a
                  href={`/patterns/${p.id}`}
                  class="flex items-center justify-between gap-3 py-3 text-sm hover:text-accent transition-colors duration-150"
                >
                  <span class="text-ink font-medium">
                    {p.data.title}
                    <span class="ml-2 font-mono text-xs text-muted/80">
                      {p.data.code}
                    </span>
                  </span>
                  <Badge label={p.data.severity} tone={sevTone(p.data.severity)} />
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </section>
</Base>
