---
import Badge from "./Badge.astro";
import { sevTone, evTone, type Pattern } from "../lib/patterns";

interface Props {
  pattern: Pattern;
  familyName?: string;
}
const { pattern, familyName } = Astro.props;
const d = pattern.data;
---

<a
  href={`/patterns/${pattern.id}`}
  class="group flex flex-col rounded-xl border border-border bg-paper p-4 transition hover:border-accent/50 hover:shadow-sm"
  data-card
  data-title={d.title.toLowerCase()}
  data-severity={d.severity}
  data-evidence={d.evidenceLevel}
  data-family={d.family}
  data-category={d.category}
  data-platforms={d.platforms.join("|")}
  data-tags={d.tags.join("|")}
>
  <div class="flex items-center justify-between gap-2">
    <span class="font-mono text-xs text-muted">{d.code}</span>
    <Badge label={d.severity} tone={sevTone(d.severity)} />
  </div>
  <h3
    class="mt-1.5 font-serif text-lg font-semibold leading-snug text-ink group-hover:text-accent"
  >
    {d.title}
  </h3>
  <p class="mt-1 flex-1 text-sm text-muted">{d.summary}</p>
  <div class="mt-3 flex flex-wrap items-center gap-1.5">
    {familyName && <Badge label={familyName} tone="neutral" />}
    <Badge label={`Evidence: ${d.evidenceLevel}`} tone={evTone(d.evidenceLevel)} />
  </div>
</a>
