---
import Badge from "./Badge.astro";
import { sevTone, evTone, purposeLabel, purposeTone, type Pattern } from "../lib/patterns";

interface Props {
  pattern: Pattern;
  familyName?: string;
}
const { pattern, familyName } = Astro.props;
const d = pattern.data;
---

<a
  href={`/patterns/${pattern.id}`}
  class="group flex flex-col rounded-2xl border border-border bg-paper p-5 card-hover-effect btn-press-active"
  data-card
  data-title={d.title.toLowerCase()}
  data-severity={d.severity}
  data-evidence={d.evidenceLevel}
  data-family={d.family}
  data-category={d.category}
  data-platforms={d.platforms.join("|")}
  data-tags={d.tags.join("|")}
  data-purpose={d.purpose}
>
  <div class="flex items-center justify-between gap-2">
    <span class="font-mono text-[10px] uppercase tracking-wider text-muted">{d.code}</span>
    <Badge label={d.severity} tone={sevTone(d.severity)} />
  </div>
  <h3
    class="mt-2 font-sans text-base font-semibold tracking-tight text-ink group-hover:text-accent transition-colors duration-150"
  >
    {d.title}
  </h3>
  <p class="mt-1 flex-1 text-xs leading-relaxed text-muted">{d.summary}</p>
  <div class="mt-4 flex flex-wrap items-center gap-1.5">
    {familyName && <Badge label={familyName} tone="neutral" />}
    <Badge label={`Evidence: ${d.evidenceLevel}`} tone={evTone(d.evidenceLevel)} />
    <Badge label={purposeLabel(d.purpose)} tone={purposeTone(d.purpose)} />
  </div>
</a>
