---
const nav = [
  { href: "/patterns", label: "Patterns" },
  { href: "/families", label: "Mechanisms" },
  { href: "/harms", label: "Harms" },
  { href: "/rubric", label: "When is it harmful?" },
  { href: "/glossary", label: "Glossary" },
  { href: "/references", label: "References" },
  { href: "/about", label: "About" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header
  class="sticky top-0 z-40 border-b border-border bg-paper/85 backdrop-blur supports-[backdrop-filter]:bg-paper/70"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4">
    <a
      href="/"
      class="font-serif text-lg font-semibold tracking-tight text-ink whitespace-nowrap"
    >
      Deceptive Patterns <span class="text-accent">in Games</span>
    </a>

    <nav class="hidden items-center gap-0.5 text-sm lg:flex" aria-label="Primary">
      {
        nav.map((n) => (
          <a
            href={n.href}
            class={`rounded-md px-2.5 py-1.5 transition hover:bg-surface ${
              isActive(n.href) ? "font-semibold text-accent" : "text-muted"
            }`}
          >
            {n.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      <a
        href="/search"
        aria-label="Search"
        class="rounded-md p-2 text-muted transition hover:bg-surface hover:text-ink"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </a>
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="rounded-md p-2 text-muted transition hover:bg-surface hover:text-ink"
      >
        <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>
        <svg class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
      </button>
    </div>
  </div>

  <nav
    class="flex gap-1 overflow-x-auto border-t border-border px-2 py-2 text-xs lg:hidden"
    aria-label="Primary mobile"
  >
    {
      nav.map((n) => (
        <a
          href={n.href}
          class={`rounded-md px-2.5 py-1.5 whitespace-nowrap ${
            isActive(n.href) ? "font-semibold text-accent" : "text-muted"
          }`}
        >
          {n.label}
        </a>
      ))
    }
  </nav>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var root = document.documentElement;
      root.classList.toggle("dark");
      try {
        localStorage.setItem(
          "theme",
          root.classList.contains("dark") ? "dark" : "light",
        );
      } catch (e) {}
    });
  })();
</script>
