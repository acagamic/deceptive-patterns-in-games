---
interface Props {
  label: string;
  tone?: string;
  href?: string;
  title?: string;
}
const { label, tone = "neutral", href, title } = Astro.props;

// Static class strings so Tailwind can detect them at build time.
const tones: Record<string, string> = {
  neutral: "bg-surface-2 text-ink/80 border-border/80",
  accent: "bg-accent-soft text-accent border-accent/20",
  "sev-low": "text-sev-low border-sev-low/20 bg-sev-low/8",
  "sev-medium": "text-sev-medium border-sev-medium/20 bg-sev-medium/8",
  "sev-high": "text-sev-high border-sev-high/20 bg-sev-high/8",
  "sev-severe": "text-sev-severe border-sev-severe/20 bg-sev-severe/8",
  "ev-strong": "text-ev-strong border-ev-strong/20 bg-ev-strong/8",
  "ev-moderate": "text-ev-moderate border-ev-moderate/20 bg-ev-moderate/8",
  "ev-emerging": "text-ev-emerging border-ev-emerging/20 bg-ev-emerging/8",
};
const cls = `inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-[11px] font-medium leading-normal whitespace-nowrap ${
  tones[tone] ?? tones.neutral
} ${href ? "hover:brightness-95 dark:hover:brightness-110 active:scale-95 transition-all duration-150 btn-press-active cursor-pointer" : ""}`;
const Tag = href ? "a" : "span";
---

<Tag class={cls} href={href} title={title}>{label}</Tag>
