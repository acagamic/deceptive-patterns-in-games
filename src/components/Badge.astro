---
interface Props {
  label: string;
  tone?: string;
  href?: string;
  title?: string;
}
const { label, tone = "neutral", href, title } = Astro.props;

// Static class strings so Tailwind can detect them at build time.
const tones: Record<string, string> = {
  neutral: "bg-surface text-muted border-border",
  accent: "bg-accent-soft text-accent border-accent/40",
  "sev-low": "text-sev-low border-sev-low/40 bg-sev-low/10",
  "sev-medium": "text-sev-medium border-sev-medium/40 bg-sev-medium/10",
  "sev-high": "text-sev-high border-sev-high/40 bg-sev-high/10",
  "sev-severe": "text-sev-severe border-sev-severe/50 bg-sev-severe/10",
  "ev-strong": "text-ev-strong border-ev-strong/40 bg-ev-strong/10",
  "ev-moderate": "text-ev-moderate border-ev-moderate/40 bg-ev-moderate/10",
  "ev-emerging": "text-ev-emerging border-ev-emerging/40 bg-ev-emerging/10",
};
const cls = `inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap ${
  tones[tone] ?? tones.neutral
} ${href ? "hover:brightness-95 transition" : ""}`;
const Tag = href ? "a" : "span";
---

<Tag class={cls} href={href} title={title}>{label}</Tag>
