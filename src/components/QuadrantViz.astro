---
import { allPatterns } from "../lib/patterns";

const patterns = await allPatterns();
const points = patterns.map((p) => ({
  slug: p.id,
  code: p.data.code,
  title: p.data.title,
  severity: p.data.severity,
  comm: p.data.communication,
}));
const vizData = { points };
---

<div class="quadviz">
  <div class="quadviz-scroll">
    <svg
      id="comm-quad-viz"
      role="img"
      aria-label="A 2-by-2 quadrant map sorting every pattern by the player-facing communication test it fails. The top row is informational pressure — Honesty (is it deceptive?) on the left, Transparency (is it hidden?) on the right. The bottom row is psychological pressure — Control (are you forced to opt in?) on the left, Consent (can you not opt out?) on the right. Dots are coloured by severity; a pattern that fails several tests sits between the quadrants, and one that fails all four sits at the centre. Nine transparent-but-exploitative patterns fail none of the four tests and are shown separately below."
    ></svg>
  </div>
  <p id="comm-quad-cap" class="quadviz-cap">
    Each dot is one pattern, placed by the communication test(s) it fails and
    coloured by <strong>severity</strong>. Hover to name it, click to open — or
    <a class="text-link underline" href="/patterns">browse all patterns</a>.
  </p>
</div>

<script type="application/json" id="comm-quad-data" set:html={JSON.stringify(vizData)}
></script>

<script>
  import { select } from "d3";
  import "d3-transition";

  const svg = document.getElementById("comm-quad-viz");
  const dataEl = document.getElementById("comm-quad-data");
  const cap = document.getElementById("comm-quad-cap");

  if (svg && dataEl) {
    const data = JSON.parse(dataEl.textContent || "{}");
    const points = data.points as any[];

    // Each dimension anchors at the CENTRE of its quadrant in unit coords
    // (x → right, y → up). A pattern sits at the mean of the anchors it fails:
    // one test → quadrant centre, two → the shared edge, all four → the centre.
    const ANCHOR: Record<string, [number, number]> = {
      honesty: [-0.5, 0.5],
      transparency: [0.5, 0.5],
      control: [-0.5, -0.5],
      consent: [0.5, -0.5],
    };
    const DIMS = ["honesty", "transparency", "control", "consent"] as const;

    const mapped: any[] = [];
    const orphans: any[] = [];
    points.forEach((p) => {
      const on = DIMS.filter((d) => p.comm?.[d]);
      if (on.length === 0) {
        orphans.push(p);
        return;
      }
      const ux = on.reduce((s, d) => s + ANCHOR[d][0], 0) / on.length;
      const uy = on.reduce((s, d) => s + ANCHOR[d][1], 0) / on.length;
      mapped.push({ ...p, ux, uy, fails: on.length });
    });

    const W = 680;
    const S = 520; // square plot
    const mL = 80,
      mT = 46;
    const trayY = mT + S + 38;
    const trayH = 92;
    const H = trayY + trayH + 8;
    svg.setAttribute("viewBox", `0 0 ${W} ${H}`);

    const cxPlot = mL + S / 2;
    const cyPlot = mT + S / 2;
    // ±0.5 (a single-test centroid) → ±S/4, the centre of each quadrant.
    const px = (ux: number) => cxPlot + ux * (S / 2);
    const py = (uy: number) => cyPlot - uy * (S / 2);

    const root = select(svg);

    // quadrant row bands — top = informational, bottom = psychological
    root
      .append("rect")
      .attr("x", mL)
      .attr("y", mT)
      .attr("width", S)
      .attr("height", S / 2)
      .attr("class", "quadviz-band-info");
    root
      .append("rect")
      .attr("x", mL)
      .attr("y", mT + S / 2)
      .attr("width", S)
      .attr("height", S / 2)
      .attr("class", "quadviz-band-psy");

    // frame + cross dividers
    root
      .append("rect")
      .attr("x", mL)
      .attr("y", mT)
      .attr("width", S)
      .attr("height", S)
      .attr("class", "quadviz-frame");
    root
      .append("line")
      .attr("x1", mL)
      .attr("y1", cyPlot)
      .attr("x2", mL + S)
      .attr("y2", cyPlot)
      .attr("class", "quadviz-divider");
    root
      .append("line")
      .attr("x1", cxPlot)
      .attr("y1", mT)
      .attr("x2", cxPlot)
      .attr("y2", mT + S)
      .attr("class", "quadviz-divider");

    // quadrant labels in the outer corners
    const pad = 16;
    const quad = [
      { name: "Honesty", q: "is it deceptive?", x: mL + pad, y: mT + 26, anchor: "start" },
      { name: "Transparency", q: "is it hidden?", x: mL + S - pad, y: mT + 26, anchor: "end" },
      { name: "Control", q: "forced to opt in?", x: mL + pad, y: mT + S - 30, anchor: "start" },
      { name: "Consent", q: "no way to opt out?", x: mL + S - pad, y: mT + S - 30, anchor: "end" },
    ];
    quad.forEach((c) => {
      root
        .append("text")
        .attr("x", c.x)
        .attr("y", c.y)
        .attr("text-anchor", c.anchor)
        .attr("class", "quadviz-qname")
        .text(c.name);
      root
        .append("text")
        .attr("x", c.x)
        .attr("y", c.y + 15)
        .attr("text-anchor", c.anchor)
        .attr("class", "quadviz-qsub")
        .text(c.q);
    });

    // row axis labels
    root
      .append("text")
      .attr("x", cxPlot)
      .attr("y", mT - 16)
      .attr("text-anchor", "middle")
      .attr("class", "quadviz-axis")
      .text("INFORMATIONAL pressure");
    root
      .append("text")
      .attr("x", cxPlot)
      .attr("y", mT + S + 24)
      .attr("text-anchor", "middle")
      .attr("class", "quadviz-axis")
      .text("PSYCHOLOGICAL pressure");

    const defaultCap = cap ? cap.innerHTML : "";
    const R = 4.4,
      sp = 12;
    const reduce =
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let dotOrder = 0;

    // hover tooltip — created up front, raised above dots on focus
    const tip = root
      .append("g")
      .attr("class", "quadviz-tip")
      .style("opacity", 0)
      .style("pointer-events", "none");
    const tipBg = tip.append("rect").attr("class", "quadviz-tip-bg").attr("rx", 5);
    const tipText = tip.append("text").attr("class", "quadviz-tip-text");

    function showTip(p: any, x: number, y: number) {
      tipText.text(`${p.code} · ${p.title}`);
      const b = (tipText.node() as SVGTextElement).getBBox();
      const padX = 9,
        padY = 5;
      let bx = x - b.width / 2 - padX;
      bx = Math.max(mL - 4, Math.min(bx, mL + S + 4 - (b.width + padX * 2)));
      const below = y - R - 14 - (b.height + padY * 2) < 0;
      const by = below ? y + R + 10 : y - R - 12 - (b.height + padY * 2);
      tipBg
        .attr("x", bx)
        .attr("y", by)
        .attr("width", b.width + padX * 2)
        .attr("height", b.height + padY * 2);
      tipText.attr("x", bx + padX).attr("y", by + padY + b.height - 3);
      tip.raise().interrupt().transition().duration(110).style("opacity", 1);
    }
    function hideTip() {
      tip.interrupt().transition().duration(120).style("opacity", 0);
    }

    function makeDot(p: any, x: number, y: number) {
      const g = root
        .append("g")
        .attr("class", "quadviz-node")
        .attr("role", "link")
        .attr("tabindex", 0)
        .attr("aria-label", `${p.title} — ${p.severity} severity`)
        .style("cursor", "pointer");
      const circle = g
        .append("circle")
        .attr("cx", reduce ? x : cxPlot)
        .attr("cy", reduce ? y : cyPlot)
        .attr("r", reduce ? R : 0)
        .attr("class", `quadviz-dot sev-${p.severity}`);
      if (!reduce) {
        // load animation: dots fly out from the centre and sort into place
        circle
          .style("opacity", 0)
          .transition()
          .delay(160 + dotOrder * 7)
          .duration(620)
          .ease((t: number) => 1 - Math.pow(1 - t, 3))
          .attr("cx", x)
          .attr("cy", y)
          .attr("r", R)
          .style("opacity", 1);
        dotOrder++;
      }
      const go = () => (window.location.href = `/patterns/${p.slug}`);
      g.on("mouseenter", () => focusDot(g, p, x, y))
        .on("mouseleave", () => blurDot(g))
        .on("focus", () => focusDot(g, p, x, y))
        .on("blur", () => blurDot(g))
        .on("click", go)
        .on("keydown", (e: any) => {
          if (e.key === "Enter") go();
        });
      return g;
    }

    // group mapped points by their centroid, then pack each group in a grid
    const groups = new Map<string, any[]>();
    mapped.forEach((p) => {
      const key = `${p.ux.toFixed(3)}|${p.uy.toFixed(3)}`;
      const arr = groups.get(key);
      if (arr) arr.push(p);
      else groups.set(key, [p]);
    });

    groups.forEach((cell) => {
      cell.sort((a, b) => a.title.localeCompare(b.title));
      const n = cell.length;
      const cols = Math.ceil(Math.sqrt(n));
      const rows = Math.ceil(n / cols);
      const cx0 = px(cell[0].ux);
      const cy0 = py(cell[0].uy);
      const y0 = cy0 - ((rows - 1) * sp) / 2;
      cell.forEach((p, k) => {
        const r = Math.floor(k / cols);
        const c = k % cols;
        const inRow = Math.min(cols, n - r * cols);
        const x = cx0 - ((inRow - 1) * sp) / 2 + c * sp;
        const y = y0 + r * sp;
        makeDot(p, x, y);
      });
    });

    // tray: transparent-but-exploitative — fails none of the four tests
    root
      .append("rect")
      .attr("x", mL)
      .attr("y", trayY)
      .attr("width", S)
      .attr("height", trayH)
      .attr("rx", 12)
      .attr("class", "quadviz-tray");
    root
      .append("text")
      .attr("x", mL + 16)
      .attr("y", trayY + 22)
      .attr("class", "quadviz-trayname")
      .text("Transparent but exploitative");
    root
      .append("text")
      .attr("x", mL + 16)
      .attr("y", trayY + 38)
      .attr("class", "quadviz-traysub")
      .text(`Fails none of the four tests — harmful anyway (${orphans.length})`);

    orphans.sort((a, b) => a.title.localeCompare(b.title));
    const on = orphans.length;
    const rowY = trayY + trayH - 26;
    const gap = (S - 40) / Math.max(on, 1);
    orphans.forEach((p, i) => {
      const x = mL + 20 + gap * (i + 0.5);
      makeDot(p, x, rowY);
    });

    function focusDot(g: any, p: any, x: number, y: number) {
      g.raise();
      g.select("circle").interrupt().attr("r", R + 2.6);
      showTip(p, x, y);
      const on = (["honesty", "transparency", "control", "consent"] as const)
        .filter((d) => p.comm?.[d])
        .map((d) => d[0].toUpperCase() + d.slice(1));
      const fails = on.length ? on.join(" · ") : "none — transparent but exploitative";
      if (cap)
        cap.innerHTML = `<strong>${p.code} · ${p.title}</strong> — ${p.severity} severity · fails: <span class="quadviz-note">${fails}</span>`;
    }
    function blurDot(g: any) {
      g.select("circle").attr("r", R);
      hideTip();
      if (cap) cap.innerHTML = defaultCap;
    }
  }
</script>

<style is:global>
  .quadviz-scroll {
    overflow-x: auto;
  }
  #comm-quad-viz {
    width: 100%;
    height: auto;
    min-width: 560px;
    display: block;
  }
  .quadviz-cap {
    margin-top: 0.85rem;
    font-size: 0.85rem;
    color: var(--muted);
    text-align: center;
    min-height: 2.6em;
  }
  .quadviz-note {
    color: var(--ink);
    font-weight: 600;
  }
  .quadviz-tip {
    transition: opacity 0.12s;
  }
  .quadviz-tip-bg {
    fill: var(--ink);
    opacity: 0.96;
  }
  .quadviz-tip-text {
    fill: var(--paper);
    font-size: 12px;
    font-weight: 600;
  }
  .quadviz-band-info {
    fill: var(--accent);
    opacity: 0.05;
  }
  .quadviz-band-psy {
    fill: var(--sev-severe);
    opacity: 0.05;
  }
  .quadviz-frame {
    fill: none;
    stroke: var(--border);
    stroke-width: 1.5;
  }
  .quadviz-divider {
    stroke: var(--border);
    stroke-width: 1.5;
    stroke-dasharray: 4 4;
  }
  .quadviz-qname {
    fill: var(--ink);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.01em;
  }
  .quadviz-qsub {
    fill: var(--muted);
    font-size: 11px;
    font-weight: 500;
  }
  .quadviz-axis {
    fill: var(--muted);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .quadviz-tray {
    fill: var(--surface);
    stroke: var(--border);
    stroke-width: 1;
  }
  .quadviz-trayname {
    fill: var(--ink);
    font-size: 12.5px;
    font-weight: 700;
  }
  .quadviz-traysub {
    fill: var(--muted);
    font-size: 11px;
    font-weight: 500;
  }
  .quadviz-node {
    transition: opacity 0.12s;
  }
  .quadviz-dot {
    stroke: var(--paper);
    stroke-width: 1;
    transition: r 0.1s ease;
  }
  .quadviz-dot.sev-Low {
    fill: var(--sev-low);
  }
  .quadviz-dot.sev-Medium {
    fill: var(--sev-medium);
  }
  .quadviz-dot.sev-High {
    fill: var(--sev-high);
  }
  .quadviz-dot.sev-Severe {
    fill: var(--sev-severe);
  }
  .quadviz-node:focus-visible {
    outline: none;
  }
  .quadviz-node:focus-visible .quadviz-dot {
    stroke: var(--accent);
    stroke-width: 2.5;
  }
</style>
