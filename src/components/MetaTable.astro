---
import Badge from "./Badge.astro";
import {
  sevTone,
  evTone,
  tagLabel,
  purposeLabel,
  purposeTone,
  purposeNote,
  type Pattern,
} from "../lib/patterns";

interface Props {
  pattern: Pattern;
  family: Map<string, string>;
  harm: Map<string, string>;
  mode: Map<string, string>;
}
const { pattern, family, harm, mode } = Astro.props;
const d = pattern.data;
const dt = "text-[10.5px] font-semibold uppercase tracking-wider text-muted/90";
const AUDIENCES = new Set(["policymakers", "developers", "children-parents"]);
const audienceTags = d.tags.filter((t) => AUDIENCES.has(t));
const regularTags = d.tags.filter((t) => !AUDIENCES.has(t));
---

<dl
  class="grid gap-x-8 gap-y-5 rounded-2xl border border-border bg-surface p-6 text-sm sm:grid-cols-2"
>
  <div>
    <dt class={dt}>Code</dt>
    <dd class="mt-1 font-mono text-ink font-medium">{d.code}</dd>
  </div>
  <div>
    <dt class={dt}>Category</dt>
    <dd class="mt-1 text-ink font-medium">{d.category}</dd>
  </div>
  <div>
    <dt class={dt}>Severity</dt>
    <dd class="mt-1"><Badge label={d.severity} tone={sevTone(d.severity)} /></dd>
  </div>
  <div>
    <dt class={dt}>Evidence</dt>
    <dd class="mt-1 flex flex-col gap-1 items-start">
      <Badge label={d.evidenceLevel} tone={evTone(d.evidenceLevel)} />
      {d.evidenceNote && <span class="text-xs text-muted/90 leading-relaxed">{d.evidenceNote}</span>}
    </dd>
  </div>
  <div class="sm:col-span-2">
    <dt class={dt}>Purpose served</dt>
    <dd class="mt-1 flex flex-col gap-1 items-start">
      <Badge label={purposeLabel(d.purpose)} tone={purposeTone(d.purpose)} />
      <span class="text-xs text-muted/90 leading-relaxed">{purposeNote(d.purpose)}</span>
    </dd>
  </div>
  <div>
    <dt class={dt}>Mechanism family</dt>
    <dd class="mt-1">
      <a class="text-link font-medium hover:underline transition-colors decoration-accent/30 underline-offset-2" href={`/families/${d.family}`}>
        {family.get(d.family) ?? d.family}
      </a>
    </dd>
  </div>
  <div>
    <dt class={dt}>Platforms</dt>
    <dd class="mt-1 text-ink font-medium">{d.platforms.join(" · ")}</dd>
  </div>
  <div>
    <dt class={dt}>Harm vectors</dt>
    <dd class="mt-1 flex flex-wrap gap-1.5">
      {d.harmVectors.map((h) => (
        <Badge label={harm.get(h) ?? h} tone="neutral" href={`/harms/${h}`} />
      ))}
    </dd>
  </div>
  <div>
    <dt class={dt}>Modes</dt>
    <dd class="mt-1 flex flex-wrap gap-1.5">
      {d.modes.map((m) => (
        <Badge label={mode.get(m) ?? m} tone="accent" href={`/rubric#modes`} />
      ))}
    </dd>
  </div>
  {
    audienceTags.length > 0 && (
      <div class="sm:col-span-2">
        <dt class={dt}>Target Audience</dt>
        <dd class="mt-1 flex flex-wrap gap-1.5">
          {audienceTags.map((t) => (
            <Badge label={tagLabel(t)} tone="accent" href={`/tags/${t}`} />
          ))}
        </dd>
      </div>
    )
  }
  <div class="sm:col-span-2">
    <dt class={dt}>Tags</dt>
    <dd class="mt-1 flex flex-wrap gap-1.5">
      {regularTags.map((t) => (
        <Badge label={tagLabel(t)} tone="neutral" href={`/tags/${t}`} />
      ))}
    </dd>
  </div>
  {
    d.aliases.length > 0 && (
      <div class="sm:col-span-2">
        <dt class={dt}>Also known as</dt>
        <dd class="mt-1 text-muted/90 font-medium">{d.aliases.join(", ")}</dd>
      </div>
    )
  }
</dl>
